<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_04" name="Inclusive Gateway" isExecutable="true">
    <bpmn:startEvent id="Start_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:inclusiveGateway id="IGW_Split" name="Inclusive Split" default="Flow_C">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_A</bpmn:outgoing>
      <bpmn:outgoing>Flow_B</bpmn:outgoing>
      <bpmn:outgoing>Flow_C</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="Task_A" name="Task A">
      <bpmn:incoming>Flow_A</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_B" name="Task B">
      <bpmn:incoming>Flow_B</bpmn:incoming>
      <bpmn:outgoing>Flow_B_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_C" name="Task C (Default)">
      <bpmn:incoming>Flow_C</bpmn:incoming>
      <bpmn:outgoing>Flow_C_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:inclusiveGateway id="IGW_Join" name="Inclusive Join">
      <bpmn:incoming>Flow_A_Join</bpmn:incoming>
      <bpmn:incoming>Flow_B_Join</bpmn:incoming>
      <bpmn:incoming>Flow_C_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:endEvent id="End_1" name="End">
      <bpmn:incoming>Flow_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="IGW_Split"/>
    <bpmn:sequenceFlow id="Flow_A" sourceRef="IGW_Split" targetRef="Task_A">
      <bpmn:conditionExpression>data["flag_a"] == true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_B" sourceRef="IGW_Split" targetRef="Task_B">
      <bpmn:conditionExpression>data["flag_b"] == true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_C" sourceRef="IGW_Split" targetRef="Task_C"/>
    <bpmn:sequenceFlow id="Flow_A_Join" sourceRef="Task_A" targetRef="IGW_Join"/>
    <bpmn:sequenceFlow id="Flow_B_Join" sourceRef="Task_B" targetRef="IGW_Join"/>
    <bpmn:sequenceFlow id="Flow_C_Join" sourceRef="Task_C" targetRef="IGW_Join"/>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="IGW_Join" targetRef="End_1"/>
  </bpmn:process>
</bpmn:definitions>
